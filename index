let cart=[], curCat='all', curSearch='';

function pct(p,o){return o?Math.round((o-p)/o*100):0}

function renderProducts(){
  const g=document.getElementById('productsGrid');
  const list=PRODUCTS.filter(p=>{
    const mc=curCat==='all'||p.cat===curCat;
    const ms=p.name.toLowerCase().includes(curSearch)||p.cat.toLowerCase().includes(curSearch);
    return mc&&ms;
  });
  if(!list.length){g.innerHTML=`<p style="color:var(--muted);grid-column:1/-1;text-align:center;padding:80px 0;font-size:1rem">No products found.</p>`;return;}
  g.innerHTML=list.map(p=>{
    const save=pct(p.price,p.old);
    const badgeClass=p.badge==='New'?'new':p.badge==='Sale'?'sale':'';
    return `<div class="pcard">
      <div class="card-img-wrap">
        ${p.badge?`<div class="card-badge ${badgeClass}">${p.badge}</div>`:''}
        <img src="${p.img}" alt="${p.name}" loading="lazy" onerror="this.style.display='none'"/>
      </div>
      <div class="card-body">
        <div class="card-cat">${p.cat}</div>
        <div class="card-name">${p.name}</div>
        <div class="card-desc">${p.desc}</div>
        <div class="card-rating">${p.rating} <span>(${p.reviews} reviews)</span></div>
        <div class="card-foot">
          <div class="price-group">
            <span class="price-now">₹${p.price.toLocaleString('en-IN')}</span>
            ${p.old?`<span class="price-old">₹${p.old.toLocaleString('en-IN')}</span><span class="price-save">${save}% off</span>`:''}
          </div>
          <button class="add-cart-btn" onclick="addCart(${p.id})" title="Add to cart">+</button>
        </div>
      </div>
    </div>`;
  }).join('');
}

function filterCat(cat,btn){
  curCat=cat;
  document.querySelectorAll('.cat-tab').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  renderProducts();
}

function doSearch(){
  curSearch=document.getElementById('searchInput').value.toLowerCase();
  renderProducts();
}

function addCart(id){
  const p=PRODUCTS.find(x=>x.id===id);
  const ex=cart.find(x=>x.id===id);
  if(ex)ex.qty++;else cart.push({...p,qty:1});
  updateCount();
  showToast(`✅ ${p.name} added!`);
}

function updateCount(){
  document.getElementById('cart-count').textContent=cart.reduce((s,x)=>s+x.qty,0);
}

function showToast(msg){
  const t=document.getElementById('toast');
  t.textContent=msg;t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'),2600);
}

function openCart(){renderCart();document.getElementById('drawerOverlay').classList.add('open')}
function closeCart(){document.getElementById('drawerOverlay').classList.remove('open')}
function handleOverlayClick(e){if(e.target===document.getElementById('drawerOverlay'))closeCart()}

function changeQty(id,delta){
  const item=cart.find(x=>x.id===id);
  if(!item)return;
  item.qty+=delta;
  if(item.qty<=0)cart=cart.filter(x=>x.id!==id);
  updateCount();renderCart();
}

function renderCart(){
  const b=document.getElementById('cartBody');
  if(!cart.length){
    b.innerHTML=`<div class="cart-empty">🛒<br><br>Your cart is empty.<br>Add some awesome products!</div>`;
    return;
  }
  const total=cart.reduce((s,p)=>s+p.price*p.qty,0);
  b.innerHTML=cart.map(p=>`
    <div class="cart-item">
      <img class="ci-img" src="${p.img}" alt="${p.name}" onerror="this.style.display='none'"/>
      <div class="ci-info">
        <div class="ci-name">${p.name}</div>
        <div class="ci-price">₹${(p.price*p.qty).toLocaleString('en-IN')}</div>
        <div class="ci-qty">
          <button class="qty-btn" onclick="changeQty(${p.id},-1)">−</button>
          <span class="qty-val">${p.qty}</span>
          <button class="qty-btn" onclick="changeQty(${p.id},1)">+</button>
        </div>
      </div>
      <button class="ci-remove" onclick="changeQty(${p.id},-999)">✕</button>
    </div>
  `).join('')+`
    <div class="cart-total-row">
      <div class="cart-total-num">Total: ₹${total.toLocaleString('en-IN')}</div>
      <button class="checkout-btn" onclick="checkout()">Place Order →</button>
    </div>`;
}

function checkout(){
  cart=[];updateCount();closeCart();
  showToast('🎉 Order placed! Thank you for shopping with ShopNest!');
}

renderProducts();
</script>

</div>

<!-- FOOTER -->
<footer>
  <div class="footer-logo">Shop<span>Nest</span>™</div>
  <p>© 2026 ShopNest · Built with ❤️ · Capstone Project</p>
  <div class="footer-links">
    <a href="#">Privacy</a>
    <a href="#">Returns</a>
    <a href="#">Contact</a>
    <a href="#">About</a>
  </div>
</footer>

<!-- TOAST -->
<div class="toast" id="toast"></div>

<!-- CART DRAWER -->
<div class="drawer-overlay" id="drawerOverlay" onclick="handleOverlayClick(event)">
  <div class="cart-drawer">
    <div class="drawer-head">
      <h2>🛒 Your Cart</h2>
      <button class="close-drawer" onclick="closeCart()">✕</button>
    </div>
    <div id="cartBody"></div>
  </div>
</div>

